{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WeWork",
  "version": "0.1.0",
  "identifier": "io.wecode.wework",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "WeWork",
        "width": 1280,
        "height": 720,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "dragDropEnabled": true,
        "trafficLightPosition": {
          "x": 19,
          "y": 21
        },
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$TEMP/**", "/var/folders/**", "/private/var/folders/**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/wegent-executor"],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  }
}
