#!/usr/bin/env sh

# Get the project root directory
PROJECT_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"

# =============================================================================
# Wework Code Formatting & Linting (lint-staged)
# =============================================================================

# Check if there are staged wework files
WEWORK_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^wework/' || true)

if [ -n "$WEWORK_FILES" ]; then
  echo "🦀 Running wework pre-commit checks..."

  cd "$PROJECT_ROOT/wework" || exit 1

  # Run lint-staged for auto-formatting staged files
  npx lint-staged

  echo "✅ Wework pre-commit checks passed"
fi
