# WeWork iOS build environment: prod
#
# iOS native apps have NO Vite dev proxy. All URLs below MUST be absolute and
# reachable from the device. Replace placeholders with real production endpoints.

VITE_API_BASE_URL=https://wework.example.com/api
VITE_SOCKET_BASE_URL=https://wework.example.com
VITE_WEGENT_BACKEND_URL=https://wework.example.com
VITE_SOCKET_PATH=/socket.io
VITE_LOGIN_MODE=all
APPLE_DEVELOPMENT_TEAM=
