# WeWork iOS build environment: staging
#
# iOS native apps have NO Vite dev proxy. All URLs below MUST be absolute and
# reachable from the simulator/device. Replace placeholders with real endpoints.

VITE_API_BASE_URL=https://wework-staging.example.com/api
VITE_SOCKET_BASE_URL=https://wework-staging.example.com
VITE_WEGENT_BACKEND_URL=https://wework-staging.example.com
VITE_SOCKET_PATH=/socket.io
VITE_LOGIN_MODE=all
APPLE_DEVELOPMENT_TEAM=
