# WeWork iOS build environment: dev
#
# iOS native apps have NO Vite dev proxy. All URLs below MUST be absolute and
# reachable from the simulator/device (do not use localhost for physical devices).
# Replace the placeholder hosts with your real backend endpoints.

# Backend origin used for the API and Socket.IO connection.
VITE_WEGENT_BACKEND_URL=https://wework-dev.example.com

# Login mode: password | oidc | all
VITE_LOGIN_MODE=all

# Apple Developer Team ID used for code signing (required for device/IPA builds).
# Leave empty to sign manually in Xcode, or override via the env of the same name.
APPLE_DEVELOPMENT_TEAM=
