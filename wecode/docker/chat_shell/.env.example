# ========== Project Configuration ==========
CHAT_SHELL_PROJECT_NAME="Chat Shell Service"
CHAT_SHELL_API_PREFIX="/api"
CHAT_SHELL_ENABLE_API_DOCS=False
CHAT_SHELL_ENVIRONMENT=production
LITELLM_LOCAL_MODEL_COST_MAP=True

# ========== Running Mode ==========
# "http" - runs as an independent HTTP service
CHAT_SHELL_MODE=http

# ========== Storage Configuration ==========
# "remote" - calls Backend API (for production HTTP mode)
CHAT_SHELL_STORAGE_TYPE=remote
# Remote storage URL (Backend internal API)
