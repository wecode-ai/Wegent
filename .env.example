# Wegent Docker Compose Configuration
# Copy this file to .env and customize as needed
# Usage: cp .env.example .env

# Frontend port (default: 3000)
# Change this if port 3000 conflicts with other development tools (e.g., Next.js, React)
# Example alternatives: 5180, 8080, 9000
WEGENT_FRONTEND_PORT=3000

# MCP (Model Context Protocol) configuration
# HTTP header key for passing username to MCP servers (sse/streamable-http only)
# The username will be sanitized to contain only safe HTTP header characters
# CHAT_MCP_SERVERS_USER_HEADER=wegent-user
