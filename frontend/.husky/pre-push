#!/usr/bin/env sh

# Navigate to project root
PROJECT_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
cd "$PROJECT_ROOT" || exit 1

# Get remote info from pre-push hook parameters
remote="$1"
url="$2"

# Check 1: Block GitHub Push
if [ -f "scripts/hooks/block-github-push.sh" ]; then
    bash scripts/hooks/block-github-push.sh "$remote" "$url"
    BLOCK_EXIT=$?
    if [ $BLOCK_EXIT -ne 0 ]; then
        exit $BLOCK_EXIT
    fi
fi

# Check 2: Run AI push gate script
if [ -f "scripts/hooks/ai-push-gate.sh" ]; then
    bash scripts/hooks/ai-push-gate.sh "$@"
    exit $?
fi

# If script doesn't exist, just pass
echo "⚠️ scripts/hooks/ai-push-gate.sh not found, skipping checks."
exit 0
